---
import type { Content } from "../i18n/types";
interface Props {
  t: Content;
}
const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-copy subtle">© {year} {t.footer.copyright}</div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
    padding: 32px 0 48px;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .footer-inner {
    display: flex;
    justify-content: center;
  }
  .footer-copy {
    font-size: 0.85rem;
  }
</style>
