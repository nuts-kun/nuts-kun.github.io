---
import type { Content, Locale } from "../i18n/types";
import LanguageToggle from "./LanguageToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang: Locale;
  t: Content;
}
const { lang, t } = Astro.props;

const navItems: { id: string; label: string }[] = [
  { id: "about", label: t.nav.about },
  { id: "education", label: t.nav.education },
  { id: "research", label: t.nav.research },
  { id: "publications", label: t.nav.publications },
  { id: "experience", label: t.nav.experience },
  { id: "awards", label: t.nav.awards },
];

const homeHref = lang === "ja" ? "/" : "/en/";
---

<a class="skip-link" href="#about">{t.ui.skipToContent}</a>

<header class="site-header">
  <div class="container header-inner">
    <a href={homeHref} class="site-logo" aria-label={t.hero.name}>
      <img class="logo-mark" src="/images/profile.jpg" alt={t.hero.name} width="32" height="32" />
      <span class="logo-name">{t.hero.name}</span>
    </a>

    <nav class="site-nav" aria-label="Section navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={`#${item.id}`} data-nav-target={item.id}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <LanguageToggle lang={lang} t={t} />
      <ThemeToggle t={t} />
    </div>
  </div>
</header>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
  }
  .skip-link:focus {
    left: 16px;
    top: 8px;
    padding: 8px 12px;
    background: var(--color-accent);
    color: white;
    border-radius: 6px;
    z-index: 1000;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-border);
    z-index: 100;
  }
  .header-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .site-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    font-weight: 600;
    text-decoration: none;
  }
  .site-logo:hover {
    text-decoration: none;
    color: var(--color-accent);
  }
  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-border);
    background: var(--color-surface-elev);
  }
  .logo-name {
    font-size: 0.95rem;
  }
  .site-nav {
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .site-nav::-webkit-scrollbar { display: none; }
  .site-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 4px;
    justify-content: center;
  }
  .site-nav a {
    display: inline-block;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .site-nav a:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    text-decoration: none;
  }
  .site-nav a.is-active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 820px) {
    .logo-name { display: none; }
  }
  @media (max-width: 640px) {
    .header-inner { gap: 12px; }
    .site-nav ul { justify-content: flex-start; }
    .site-nav a { padding: 4px 8px; font-size: 0.85rem; }
  }
</style>

<script is:inline>
  (() => {
    const navLinks = document.querySelectorAll(".site-nav a[data-nav-target]");
    if (!navLinks.length) return;
    const sections = Array.from(navLinks)
      .map((a) => document.getElementById(a.getAttribute("data-nav-target")))
      .filter((el) => el !== null);
    if (!sections.length) return;

    const linkByTarget = new Map();
    navLinks.forEach((a) => linkByTarget.set(a.getAttribute("data-nav-target"), a));

    const visible = new Set();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) visible.add(entry.target.id);
          else visible.delete(entry.target.id);
        });
        const firstVisible = sections.find((s) => visible.has(s.id));
        navLinks.forEach((a) => a.classList.remove("is-active"));
        if (firstVisible) {
          const active = linkByTarget.get(firstVisible.id);
          if (active) active.classList.add("is-active");
        }
      },
      { rootMargin: "-30% 0px -55% 0px", threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
  })();
</script>
