---
import type { TimelineItem } from "../i18n/types";

interface Props {
  items: TimelineItem[];
}
const { items } = Astro.props;
---

<ul class="timeline">
  {items.map((it) => (
    <li class="timeline-item">
      <div class="timeline-period">{it.period}</div>
      <div class="timeline-body">
        <div class="timeline-org">
          {it.orgUrl ? (
            <a href={it.orgUrl} target="_blank" rel="noopener noreferrer">{it.org}</a>
          ) : it.org}
        </div>
        {it.title && <div class="timeline-title">{it.title}</div>}
        {it.detail && <div class="timeline-detail">{it.detail}</div>}
      </div>
    </li>
  ))}
</ul>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 16px;
    padding: 10px 16px;
    border-left: 2px solid var(--color-border-strong);
    background: var(--color-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    border-top: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    transition: border-left-color 0.15s ease;
  }
  .timeline-item:hover {
    border-left-color: var(--color-accent);
  }
  .timeline-period {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.88rem;
    padding-top: 3px;
  }
  .timeline-org {
    font-weight: 700;
    color: var(--color-text);
    font-size: 1.02rem;
    line-height: 1.4;
  }
  .timeline-org a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .timeline-org a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .timeline-title {
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.88rem;
    line-height: 1.45;
    margin-top: 2px;
  }
  .timeline-detail {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed var(--color-border);
  }
  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
